# Flash Sale System env contract (PRD section 8.4 / NFR-7). Copy to .env for local dev.

# Sale window — required, ISO 8601; any timezone offset is normalized to UTC at boot.
SALE_START_TIME=2026-07-10T04:00:00Z
SALE_END_TIME=2026-07-10T05:00:00Z

# Units for sale — positive integer (default 100).
STOCK_QUANTITY=100

# Connections (defaults shown).
REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb://localhost:27017/flash-sale

# API port (default 3000).
PORT=3000

# Write-Behind worker mode.
# true  → worker runs inside the API process (single container, simple deploys).
# false / unset → run the worker separately: node server/src/worker/index.ts
WORKER_COLOCATED=true
