# Flash Sale System env contract (Story 6-1). Copy to .env for local dev.
#
# Sale timing, stock quantity, slug, name, and product pricing are now stored
# in MongoDB and read at boot — NOT configured via env vars. Provision sale
# and product data before the first server start:
#
#   node db/scripts/seed-db.ts
#
# ── Infrastructure Connections ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb://localhost:27017/flash-sale

# ── API Port ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Redis Timeouts (ms) ───────────────────────────────────────────────────────
# Boot connect timeout. TLS/cluster/Atlas may need 5000+.
REDIS_CONNECT_TIMEOUT_MS=2000
# Per-command timeout. Increase for high-latency envs; lower for strict SLOs.
REDIS_COMMAND_TIMEOUT_MS=1000
# Reconnect backoff ceiling. Raise if Redis failover takes longer than 2s.
REDIS_RECONNECT_MAX_MS=2000

# ── MongoDB Timeouts (ms) ─────────────────────────────────────────────────────
# Server-selection timeout. Atlas replica-set elections can exceed 5000.
MONGO_SELECTION_TIMEOUT_MS=5000

# ── HTTP Server ───────────────────────────────────────────────────────────────
# Express JSON body size limit. Increase if your gateway pre-aggregates chunks.
HTTP_BODY_LIMIT=8kb

# ── Sale Resolver Cache ───────────────────────────────────────────────────────
# Slug→sale in-memory cache TTL in ms (max 60000). Lower in dev for faster
# iteration; keep at 60000 in prod.
SALE_RESOLVER_CACHE_TTL_MS=60000

# ── Write-Behind Worker Mode ──────────────────────────────────────────────────
# true  → worker runs inside the API process (single-container deploys).
# false → run the worker as a separate process: node server/src/worker/index.ts
WORKER_COLOCATED=false

# ── Worker Consumer ID & Group (finding #7) ──────────────────────────────────
# Consumer name: unique per worker replica. PEL re-delivery is scoped per
# consumer name, so duplicate names across pods cause redundant DB writes.
# Defaults to "worker-<hostname>" if unset.
# WORKER_CONSUMER_ID=
#
# Consumer group: shared by all workers draining the same stream. Override
# only when running independent consumer groups (e.g., analytics vs. audit).
# Defaults to "workers".
# WORKER_GROUP=workers

# ── Vite Dev Server (client only, not read by the API) ───────────────────────
VITE_PORT=5173
VITE_API_URL=http://localhost:3000
